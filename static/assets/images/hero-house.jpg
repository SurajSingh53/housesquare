<svg xmlns="http://www.w3.org/2000/svg" width="900" height="600" viewBox="0 0 900 600">
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#87CEEB"/>
      <stop offset="100%" stop-color="#E8DDD0"/>
    </linearGradient>
  </defs>
  <rect width="900" height="600" fill="url(#sky)"/>
  <!-- Ground -->
  <rect y="440" width="900" height="160" fill="#8B7355"/>
  <!-- House body -->
  <rect x="200" y="200" width="500" height="280" fill="#F5F0E8"/>
  <!-- Roof -->
  <polygon points="150,200 450,60 750,200" fill="#C8654A"/>
  <!-- Door -->
  <rect x="390" y="360" width="120" height="120" fill="#8B4513" rx="4"/>
  <circle cx="497" cy="422" r="6" fill="#C9A84C"/>
  <!-- Windows -->
  <rect x="240" y="260" width="100" height="80" fill="#87CEEB" rx="4"/>
  <line x1="290" y1="260" x2="290" y2="340" stroke="#E8DDD0" stroke-width="2"/>
  <line x1="240" y1="300" x2="340" y2="300" stroke="#E8DDD0" stroke-width="2"/>
  <rect x="560" y="260" width="100" height="80" fill="#87CEEB" rx="4"/>
  <line x1="610" y1="260" x2="610" y2="340" stroke="#E8DDD0" stroke-width="2"/>
  <line x1="560" y1="300" x2="660" y2="300" stroke="#E8DDD0" stroke-width="2"/>
  <!-- Trees -->
  <rect x="80" y="360" width="20" height="80" fill="#8B7355"/>
  <ellipse cx="90" cy="340" rx="40" ry="50" fill="#2ECC71"/>
  <rect x="780" y="370" width="20" height="70" fill="#8B7355"/>
  <ellipse cx="790" cy="350" rx="35" ry="45" fill="#27AE60"/>
  <!-- Sun -->
  <circle cx="100" cy="100" r="50" fill="#F9CA24" opacity="0.8"/>
  <!-- Label -->
  <rect x="30" y="540" width="840" height="50" fill="rgba(30,30,30,0.7)" rx="6"/>
  <text x="450" y="572" text-anchor="middle" fill="white" font-family="Georgia" font-size="18" font-weight="bold">HouseSquare — Find Your Perfect Address</text>
</svg>