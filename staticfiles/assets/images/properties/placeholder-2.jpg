<svg xmlns="http://www.w3.org/2000/svg" width="600" height="400" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="bg_prop-2" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#4A7CC8" stop-opacity="0.85"/>
      <stop offset="100%" stop-color="#4A7CC8" stop-opacity="0.55"/>
    </linearGradient>
  </defs>
  <!-- Background -->
  <rect width="600" height="400" fill="#E8DDD0"/>
  <!-- Geometric house illustration -->
  <rect x="100" y="160" width="400" height="200" fill="white" opacity="0.9" rx="4"/>
  <polygon points="80,160 300,60 520,160" fill="#4A7CC8" opacity="0.9"/>
  <!-- Door -->
  <rect x="260" y="260" width="80" height="100" fill="#4A7CC8" rx="3"/>
  <circle cx="328" cy="312" r="5" fill="white"/>
  <!-- Windows -->
  <rect x="140" y="200" width="70" height="55" fill="#4A7CC8" rx="3" opacity="0.5"/>
  <rect x="390" y="200" width="70" height="55" fill="#4A7CC8" rx="3" opacity="0.5"/>
  <!-- Overlay gradient -->
  <rect width="600" height="400" fill="url(#bg_prop-2)"/>
  <!-- Icon -->
  <text x="300" y="130" text-anchor="middle" font-size="48">🏡</text>
  <!-- Info bar -->
  <rect y="300" width="600" height="100" fill="rgba(30,30,30,0.72)"/>
  <text x="24" y="334" font-family="Georgia,serif" font-size="16" font-weight="bold" fill="white">Luxury Villa</text>
  <text x="24" y="356" font-family="Arial,sans-serif" font-size="12" fill="rgba(255,255,255,0.7)">📍 Jubilee Hills, Hyderabad</text>
  <rect x="430" y="316" width="150" height="36" fill="#4A7CC8" rx="4"/>
  <text x="505" y="339" text-anchor="middle" font-family="Georgia,serif" font-size="16" font-weight="bold" fill="white">₹4.2 Cr</text>
</svg>